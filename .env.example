# ─── Supabase ───
# Find these at: https://supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Database ───
# Find at: Supabase → Settings → Database → Connection String → Transaction Pooler (Port 6543)
# IMPORTANT: Transaction Pooler (6543), NOT Session Pooler (5432) — Serverless needs pgbouncer
DATABASE_URL=postgresql://postgres.YOUR-PROJECT-REF:YOUR-PASSWORD@aws-1-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=10

# For migrations / introspection use the direct database connection (not the pooler).
DIRECT_URL=postgresql://postgres:<PASSWORD>@db.<PROJECT_REF>.supabase.co:5432/postgres

# ─── LLM Provider (openai | claude | gemini) ───
# Pick ONE: openai | claude | gemini
LLM_PROVIDER=openai

# OpenAI (if LLM_PROVIDER=openai)
# Get key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o

# Anthropic (if LLM_PROVIDER=claude)
# Get key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-20250514

# Google (if LLM_PROVIDER=gemini)
# Get key at: https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=...
GEMINI_MODEL=gemini-2.0-flash

# ─── Optional ───
# Tavily (web research for data-grounded personas)
# Get key at: https://tavily.com → Dashboard → API Keys
# Without this, personas are generated from your product description only.
TAVILY_API_KEY=tvly-...

# Outscraper (Google Reviews extraction — used by /admin)
# Get key at: https://outscraper.com → Account → API Keys
# Optional — only needed for admin reviews functionality
OUTSCRAPER_API_KEY=your-outscraper-api-key
OUTSCRAPER_API_BASE_URL=https://api.app.outscraper.com

# ─── Inngest (Background Jobs) ───
# Find at: Inngest Dashboard → your app → Keys
INNGEST_EVENT_KEY=your-inngest-event-key
INNGEST_SIGNING_KEY=your-inngest-signing-key

# ─── App URL ───
# Must match the port in package.json
NEXT_PUBLIC_APP_URL=http://localhost:3004

# Optional: admin allowlist (comma separated) for dev tooling / elevated UI
GOTOFU_ADMIN_EMAILS=your-email@example.com
