# ══════════════════════════════════════════════════════════════════════
# GoTofu — Environment Variables
# ══════════════════════════════════════════════════════════════════════
#
# SETUP:
#   1. Copy this file to .env.local    →  cp .env.example .env.local
#   2. Copy this file to .env          →  cp .env.example .env
#   3. Fill in your values in BOTH files (same values, both needed)
#
# WHY TWO FILES?
#   .env.local  = Read by Next.js (your app)
#   .env        = Read by Prisma CLI (prisma db push, prisma generate)
#   Prisma can't read .env.local — that's a Prisma limitation.
#   Both files are gitignored, so your secrets are safe.
#
# ══════════════════════════════════════════════════════════════════════

# ─── Supabase ───
# Find these at: https://supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Database ───
# Find at: Supabase → Settings → Database → Connection String → Transaction Pooler (Port 6543)
# WICHTIG: Transaction Pooler (6543), NICHT Session Pooler (5432) — Serverless braucht pgbouncer
DATABASE_URL=postgresql://postgres.YOUR-PROJECT-REF:YOUR-PASSWORD@aws-1-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=10

# ─── LLM Provider ───
# Pick ONE: openai | claude | gemini
LLM_PROVIDER=openai

# OpenAI (if LLM_PROVIDER=openai)
# Get key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o

# Anthropic (if LLM_PROVIDER=claude)
# Get key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-20250514

# Google (if LLM_PROVIDER=gemini)
# Get key at: https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=...
GEMINI_MODEL=gemini-2.0-flash

# ─── Optional ───
# Tavily (web research for data-grounded personas)
# Get key at: https://tavily.com → Dashboard → API Keys
# Without this, personas are generated from your product description only.
TAVILY_API_KEY=tvly-...

# ─── Inngest (Background Jobs) ───
# Find at: Inngest Dashboard → your app → Keys
INNGEST_EVENT_KEY=your-inngest-event-key
INNGEST_SIGNING_KEY=your-inngest-signing-key

# ─── App URL ───
# Must match the port in package.json
NEXT_PUBLIC_APP_URL=http://localhost:3004
