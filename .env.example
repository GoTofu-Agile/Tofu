# ─── Supabase ───
# Find these at: https://supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Database ───
# Find at: Supabase → Settings → Database → Connection String → Transaction Pooler (Port 6543)
# IMPORTANT: Transaction Pooler (6543), NOT Session Pooler (5432) — Serverless needs pgbouncer
DATABASE_URL=postgresql://postgres.YOUR-PROJECT-REF:YOUR-PASSWORD@aws-1-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=10

# For migrations / introspection use the direct database connection (not the pooler).
DIRECT_URL=postgresql://postgres:<PASSWORD>@db.<PROJECT_REF>.supabase.co:5432/postgres

# ─── LLM Provider (openai | claude | gemini) ───
# Pick ONE: openai | claude | gemini
LLM_PROVIDER=openai

# OpenAI (if LLM_PROVIDER=openai)
# Get key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o

# Anthropic (if LLM_PROVIDER=claude)
# Get key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-20250514

# Google (if LLM_PROVIDER=gemini)
# Get key at: https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=...
GEMINI_MODEL=gemini-2.0-flash

# ─── Optional ───
# Tavily (web research for data-grounded personas)
# Get key at: https://tavily.com → Dashboard → API Keys
# Without this, personas are generated from your product description only.
TAVILY_API_KEY=tvly-...

# SerpAPI (App Store / Play Store reviews via /api/reviews/appstore; extra SERP snippets in quick research)
# Get key at: https://serpapi.com/manage-api-key
SERPAPI_API_KEY=
# Optional: max SerpAPI HTTP calls per quick-research request (default 8). Core quick research uses up to 4 calls;
# when clients send serpOptions.modes (deep research), budget 16–24+ so extended engines (Maps, YouTube, Jobs, Scholar, app search, forums) can run.
SERPAPI_MAX_CALLS_PER_REQUEST=8
SERPAPI_ENABLED=true

# Outscraper (deprecated — replaced by SerpAPI for store reviews; remove when no longer needed)
# OUTSCRAPER_API_KEY=
# OUTSCRAPER_API_BASE_URL=https://api.app.outscraper.com

# ─── Email (Resend) ───
# Get key at: https://resend.com → API Keys
RESEND_API_KEY=re_...

# ─── Inngest (Background Jobs) ───
# Find at: Inngest Dashboard → your app → Keys
INNGEST_EVENT_KEY=your-inngest-event-key
INNGEST_SIGNING_KEY=your-inngest-signing-key

# ─── App URL ───
# Must match how you open the app (port = package.json). Use 127.0.0.1 for Cursor Simple Browser.
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3004

# ─── Stripe Billing (monthly) ───
# Use your active Stripe account keys from Stripe Dashboard → Developers → API keys / Webhooks.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_PILOT_MONTHLY=price_...
STRIPE_PRICE_ID_BUILDER_MONTHLY=price_...
STRIPE_PRICE_ID_STUDIO_MONTHLY=price_...
# Optional ops references (not required by app runtime):
# STRIPE_RESTRICTED_KEY=rk_live_...
# STRIPE_WEBHOOK_DESTINATION_ID=we_...
# STRIPE_PRODUCT_ID_PILOT=prod_...
# STRIPE_PRODUCT_ID_BUILDER=prod_...
# STRIPE_PRODUCT_ID_STUDIO=prod_...

# Optional: admin allowlist (comma separated) for dev tooling / elevated UI
GOTOFU_ADMIN_EMAILS=your-email@example.com

# ─── Cursor / VS Code in-editor browser (optional) ───
# If the app works in Chrome/Safari but not in Cursor’s Simple Browser or “Ports” preview,
# paste the preview host here (no https://), comma-separated. Example:
# ALLOWED_DEV_ORIGINS=abc-123.usw2.cursorapp.com:443
# Also set NEXT_PUBLIC_APP_URL to the same base URL you open in the preview (for Supabase auth redirects).
ALLOWED_DEV_ORIGINS=
