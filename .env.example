# ─── Database (Supabase PostgreSQL) ───
# Prisma runtime should use the Supabase *transaction pooler* (PgBouncer) to avoid "max clients reached" in Next dev/serverless.
# Use port 6543 and enable Prisma's PgBouncer mode + keep connections low.
DATABASE_URL=postgresql://postgres.<PROJECT_REF>:<PASSWORD>@aws-1-<REGION>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1

# For migrations / introspection use the direct database connection (not the pooler).
DIRECT_URL=postgresql://postgres:<PASSWORD>@db.<PROJECT_REF>.supabase.co:5432/postgres

